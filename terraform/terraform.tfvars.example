# ==============================================================================
# Janus Terraform Configuration — Example Values
# ==============================================================================
# Copy this file to staging.tfvars or production.tfvars and fill in your values.
# Usage: terraform plan -var-file=environments/staging.tfvars
# ==============================================================================

# ------------------------------------------------------------------------------
# General
# ------------------------------------------------------------------------------
project_name = "janus"
environment  = "staging"
region       = "us-east-1"
domain_name  = "janus.example.com"

# ------------------------------------------------------------------------------
# VPC
# ------------------------------------------------------------------------------
vpc_cidr           = "10.0.0.0/16"
availability_zones = ["us-east-1a", "us-east-1b"]

# ------------------------------------------------------------------------------
# RDS PostgreSQL
# ------------------------------------------------------------------------------
db_instance_class          = "db.t4g.micro"
db_name                    = "janus"
db_username                = "janus_admin"
enable_multi_az            = false
db_backup_retention_period = 7

# ------------------------------------------------------------------------------
# ElastiCache Redis
# ------------------------------------------------------------------------------
redis_node_type       = "cache.t4g.micro"
redis_num_cache_nodes = 1

# ------------------------------------------------------------------------------
# ECS — API
# ------------------------------------------------------------------------------
api_desired_count = 1
api_min_count     = 1
api_max_count     = 4
api_cpu           = 512   # 0.5 vCPU
api_memory        = 1024  # 1 GB

# ------------------------------------------------------------------------------
# ECS — Dashboard
# ------------------------------------------------------------------------------
dashboard_desired_count = 1
dashboard_min_count     = 1
dashboard_max_count     = 4
dashboard_cpu           = 256   # 0.25 vCPU
dashboard_memory        = 512   # 0.5 GB

# ------------------------------------------------------------------------------
# Tags
# ------------------------------------------------------------------------------
tags = {
  Team = "platform"
}
