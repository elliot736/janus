{
  "name": "janus",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "eslint . --ext .ts,.tsx",
    "db:generate": "turbo db:generate --filter=@janus/api",
    "db:migrate": "turbo db:migrate --filter=@janus/api",
    "db:push": "turbo db:push --filter=@janus/api"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "eslint": "^9.16.0",
    "fumadocs-core": "^15.8.5",
    "next": "^15.5.14",
    "turbo": "^2",
    "typescript-eslint": "^8.0.0"
  },
  "packageManager": "npm@10.8.0",
  "engines": {
    "node": ">=20"
  }
}
